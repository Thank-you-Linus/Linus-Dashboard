# Environment variables for Linus Dashboard development
# Copy this file to .env and modify as needed

# Home Assistant configuration
PYTHONPATH="./custom_components"

# Development settings
DEBUG=true
HASS_CONFIG_DIR="./config"

# Optional: Set Home Assistant data directory
# HASS_DATA_DIR="./config"

# Optional: Set timezone
# TZ="Europe/Paris"

# Used by `make fake-house` / `make bootstrap` (provisions the fake house
# test entities): a long-lived access token. You don't need to set this
# yourself — `make bootstrap` (or the fake-house-watch background process
# started automatically by the devcontainer) creates the HA admin account
# and this token via the API and writes it here on its own, no browser
# needed. Only set it manually if you already have a token from the HA UI
# (Profile > Security > Tokens) you'd rather reuse.
# HA_TOKEN=

# Only used by config/bootstrap_ha_onboarding.py, and only if this instance
# was already onboarded by hand at some point and .env's HA_TOKEN got lost
# (a fresh instance doesn't need these — the admin account is created
# automatically with a random password, printed once when it happens).
# HA_ADMIN_USERNAME=admin
# HA_ADMIN_PASSWORD=
