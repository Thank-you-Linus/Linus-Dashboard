# .sapiens/tools - Linus Dashboard project
# Format: key=command (one per line, # for comments)

# Project metadata
type=typescript
pm=npm

# Quality checks
lint=npm run lint:check
lint:fix=npm run lint
types=npm run type-check
test=npm run test
test:watch=npm run test:watch
coverage=npm run test:coverage
build=npm run build
build:prod=npm run build:prod

# Smoke / CI
test:smoke=npm run test:smoke
test:ci=npm run test:ci

# Development
install=npm install
serve=npm run build:dev

# Release helpers
release:check=npm run release:check
release:validate=npm run release:validate
release:changelog=npm run release:changelog
release:notes=npm run release:notes
