#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

echo "🔧 Setting up Linus Dashboard development environment..."

# Create Python virtual environment if it doesn't exist
if [[ ! -d "ha-env" ]]; then
    echo "🐍 Creating Python virtual environment..."
    python3 -m venv ha-env
fi

# Activate virtual environment
echo "🔌 Activating virtual environment..."
source ha-env/bin/activate

# Upgrade pip
echo "⬆️ Upgrading pip..."
python -m pip install --upgrade pip

# Install Python requirements
echo "📚 Installing Python dependencies..."
python -m pip install --requirement requirements.txt

# Pre-install ALL HA component dependencies to avoid runtime install failures.
# HA lazily installs component requirements at startup, which fails in our dev environment.
# We scan every manifest.json in the installed HA package and install all requirements
# upfront, so the server starts cleanly regardless of which components get loaded.
echo "🔌 Pre-installing Home Assistant component dependencies..."
python - << 'PYEOF'
import glob, json, os, subprocess, sys

ha_pattern = os.path.join(os.getcwd(), "ha-env", "lib", "python*", "site-packages", "homeassistant", "components")
matches = glob.glob(ha_pattern)
if not matches:
    print("  ⚠️  HA not installed yet, skipping component dependency resolution.")
    sys.exit(0)

ha_components = matches[0]
requirements = set()
for comp in os.listdir(ha_components):
    manifest = os.path.join(ha_components, comp, "manifest.json")
    if os.path.exists(manifest):
        try:
            data = json.loads(open(manifest).read())
            requirements.update(data.get("requirements", []))
        except Exception:
            pass

print(f"  Installing {len(requirements)} component requirement(s) (already-installed packages will be skipped)...")
result = subprocess.run([sys.executable, "-m", "pip", "install", "--quiet"] + sorted(requirements))
if result.returncode != 0:
    print("  ⚠️  Some requirements failed to install (non-fatal, may be platform-specific packages).")
else:
    print("  ✅ All component dependencies ready.")
PYEOF

# Note: Node.js dependencies will be installed by postStartCommand
echo "✅ Python setup completed!"
echo "   Node.js dependencies will be installed automatically after container startup."

# Create .env file from example if it doesn't exist
if [[ ! -f ".env" && -f ".env.example" ]]; then
    echo "📄 Creating .env file from example..."
    cp .env.example .env
fi

# Create config directory if it doesn't exist
if [[ ! -d "config" ]]; then
    echo "📁 Creating Home Assistant config directory..."
    mkdir -p config
fi

echo "✅ Setup complete!"
echo ""
echo "🎯 Next steps:"
echo "  1. Review and modify .env file if needed"
echo "  2. Start development server: ./scripts/develop"
echo "  3. Build frontend: npm run build"
